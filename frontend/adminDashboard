<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Dashboard - SkillsConnect</title>
    <link rel="stylesheet" href="style.css">
    <style>
        .dashboard-wrapper {
            min-height: 100vh;
            background-color: #666666;
            display: flex;
            flex-direction: column;
        }

        /* NAVBAR */
        .navbar {
            background-color: #333333;
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 2px solid white;
        }

        .navbar h1 {
            color: white;
            font-size: 20px;
            margin: 0;
        }

        .navbar-right {
            display: flex;
            align-items: center;
            gap: 15px;
            color: white;
            font-size: 14px;
        }

        .logout-btn {
            background-color: crimson;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 14px;
            margin-top: 0;
        }

        .logout-btn:hover {
            opacity: 0.85;
            background-color: crimson;
            color: white;
        }

        /* MAIN CONTENT */
        .dashboard-content {
            padding: 30px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        /* WELCOME CARD */
        .welcome-card {
            background-color: #545454;
            border: 2px solid white;
            border-radius: 12px;
            padding: 25px;
            color: white;
        }

        .welcome-card h2 {
            margin: 0 0 8px 0;
            font-size: 24px;
        }

        .welcome-card p {
            margin: 0;
            color: #ccc;
            font-size: 14px;
        }

        /* INFO CARDS ROW */
        .cards-row {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 20px;
        }

        .info-card {
            background-color: #545454;
            border: 2px solid white;
            border-radius: 12px;
            padding: 20px;
            color: white;
            text-align: center;
        }

        .info-card h3 {
            margin: 0 0 8px 0;
            font-size: 14px;
            color: #ccc;
            text-transform: uppercase;
        }

        .info-card p {
            margin: 0;
            font-size: 18px;
            font-weight: bold;
        }

        /* PROFILE SECTION */
        .profile-section {
            background-color: #545454;
            border: 2px solid white;
            border-radius: 12px;
            padding: 25px;
            color: white;
        }

        .profile-section h2 {
            margin: 0 0 20px 0;
            border-left: 5px solid white;
            padding-left: 10px;
        }

        .profile-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        .profile-field {
            display: flex;
            flex-direction: column;
            gap: 4px;
        }

        .profile-field label {
            font-size: 12px;
            color: #ccc;
            text-transform: uppercase;
            margin: 0;
        }

        .profile-field p {
            margin: 0;
            font-size: 15px;
            font-weight: bold;
        }

        /* PERMISSIONS SECTION */
        .permissions-section {
            background-color: #545454;
            border: 2px solid white;
            border-radius: 12px;
            padding: 25px;
            color: white;
        }

        .permissions-section h2 {
            margin: 0 0 15px 0;
            border-left: 5px solid white;
            padding-left: 10px;
        }

        .permissions-list {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .permission-badge {
            background-color: #333;
            border: 1px solid white;
            color: white;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 13px;
        }
    </style>
</head>
<body>
    <div class="dashboard-wrapper">

        <!-- NAVBAR -->
        <nav class="navbar">
            <h1>SkillsConnect — Admin</h1>
            <div class="navbar-right">
                <span id="navName"></span>
                <button class="logout-btn" id="logoutBtn">Logout</button>
            </div>
        </nav>

        <!-- MAIN CONTENT -->
        <div class="dashboard-content">

            <!-- WELCOME -->
            <div class="welcome-card">
                <h2 id="welcomeMsg">Welcome 👋</h2>
                <p>Admin Dashboard</p>
            </div>

            <!-- INFO CARDS -->
            <div class="cards-row">
                <div class="info-card">
                    <h3>Role</h3>
                    <p>Admin</p>
                </div>
                <div class="info-card">
                    <h3>Username</h3>
                    <p id="cardUsername">-</p>
                </div>
                <div class="info-card">
                    <h3>Status</h3>
                    <p id="cardStatus">-</p>
                </div>
            </div>

            <!-- PROFILE -->
            <div class="profile-section">
                <h2>Admin Profile</h2>
                <div class="profile-grid">
                    <div class="profile-field">
                        <label>Full Name</label>
                        <p id="profileName">-</p>
                    </div>
                    <div class="profile-field">
                        <label>Email</label>
                        <p id="profileEmail">-</p>
                    </div>
                    <div class="profile-field">
                        <label>Username</label>
                        <p id="profileUsername">-</p>
                    </div>
                    <div class="profile-field">
                        <label>Status</label>
                        <p id="profileStatus">-</p>
                    </div>
                </div>
            </div>

            <!-- PERMISSIONS -->
            <div class="permissions-section">
                <h2>Permissions</h2>
                <div class="permissions-list" id="permissionsList">
                    <p style="color:#ccc;">No permissions found.</p>
                </div>
            </div>

        </div>
    </div>

    <script>
        // ── PROTECT PAGE ────────────────────────────
        const sessionToken = localStorage.getItem("sessionToken");
        const email        = localStorage.getItem("userEmail");
        const name         = localStorage.getItem("userName");
        const role         = localStorage.getItem("userRole");
        const username     = localStorage.getItem("userUsername")    || "-";
        const status       = localStorage.getItem("userStatus")      || "-";
        const permissions  = localStorage.getItem("userPermissions") || "";

        if (!sessionToken) {
            alert("You must log in first!");
            window.location.href = "index.html";
        }

        // Only allow admins
        if (role !== "admin") {
            alert("Access denied.");
            window.location.href = "index.html";
        }

        // ── DISPLAY USER DATA ───────────────────────
        const displayName = name || email || "Admin";

        document.getElementById("navName").innerText          = displayName;
        document.getElementById("welcomeMsg").innerText       = "Welcome, " + displayName + " 👋";
        document.getElementById("cardUsername").innerText     = username;
        document.getElementById("cardStatus").innerText       = status;
        document.getElementById("profileName").innerText      = name     || "-";
        document.getElementById("profileEmail").innerText     = email    || "-";
        document.getElementById("profileUsername").innerText  = username;
        document.getElementById("profileStatus").innerText    = status;

        // ── DISPLAY PERMISSIONS ─────────────────────
        if (permissions) {
            const permList = document.getElementById("permissionsList");
            permList.innerHTML = "";
            const permsArray = permissions.split(",");
            permsArray.forEach(perm => {
                const badge = document.createElement("span");
                badge.className   = "permission-badge";
                badge.innerText   = perm.trim();
                permList.appendChild(badge);
            });
        }

        // ── LOGOUT ──────────────────────────────────
        document.getElementById("logoutBtn").addEventListener("click", async () => {
            try {
                await fetch("http://localhost:3000/logout", {
                    method:  "POST",
                    headers: { "Authorization": sessionToken }
                });
            } catch (error) {
                console.error("Logout error:", error);
            }
            localStorage.clear();
            window.location.href = "index.html";
        });
    </script>
</body>
</html>